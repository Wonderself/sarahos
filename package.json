{
  "name": "sarah-os",
  "version": "0.10.0",
  "description": "SARAH OS — Synthetic Autonomous Resident Agent Hierarchy Operating System",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --testPathIgnorePatterns __integration__",
    "test:unit": "jest --testPathIgnorePatterns __integration__",
    "test:integration": "jest --testPathPattern __integration__",
    "test:all": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ignore-pattern src/dashboard",
    "lint:fix": "eslint src/ --fix --ignore-pattern src/dashboard",
    "format": "prettier --write \"src/**/*.ts\" --ignore-path .prettierignore",
    "db:init": "tsx scripts/seed-data.ts",
    "db:seed-users": "tsx scripts/seed-users.ts",
    "db:remove-test-users": "tsx scripts/remove-test-users.ts",
    "health": "tsx scripts/health-check.ts"
  },
  "keywords": [
    "ai",
    "multi-agent",
    "autonomous",
    "os"
  ],
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "bullmq": "^5.34.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1",
    "pgvector": "^0.2.0",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
