# ═══════════════════════════════════════════
# FREENZY.IO — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════

# ── General ──
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ── PostgreSQL ──
DATABASE_URL=postgresql://freenzy:change-me-in-production@localhost:5432/freenzy
DB_HOST=localhost
DB_PORT=5432
DB_NAME=freenzy
DB_USER=freenzy
DB_PASSWORD=change-me-in-production

# ── Redis ──
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Anthropic (Claude) ──
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
CLAUDE_MODEL_FAST=claude-sonnet-4-20250514
CLAUDE_MODEL_STANDARD=claude-sonnet-4-20250514
CLAUDE_MODEL_ADVANCED=claude-opus-4-6

# ── Avatar Pipeline ──
AVATAR_PYTHON_URL=http://localhost:8000
DID_API_KEY=
ASSEMBLYAI_API_KEY=
TELNYX_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Embeddings ──
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-ada-002

# ── Security ──
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h
ENCRYPTION_KEY=change-me-32-byte-key-here!!!!!

# ── API Keys (comma-separated for multiple keys per role) ──
API_KEYS_ADMIN=admin-key-change-me
API_KEYS_OPERATOR=operator-key-change-me
API_KEYS_VIEWER=viewer-key-change-me
API_KEYS_SYSTEM=system-key-change-me

# ── Dashboard ──
DASHBOARD_ORIGIN=http://localhost:3001

# ── Rate Limiting ──
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# ── User Tiers ──
DEMO_DEFAULT_DAYS=7
GUEST_DAILY_LIMIT=10
FREE_DAILY_LIMIT=100
PAID_DAILY_LIMIT=10000

# ── Financial ──
CHARITY_PERCENTAGE=20

# ── Billing ──
TOKEN_MARGIN_PERCENT=20
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── WhatsApp Cloud API (Meta Business) ──
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=freenzy-webhook-verify-2026
WHATSAPP_API_VERSION=v18.0
WEBHOOK_BASE_URL=http://localhost:3010

# ── Deepgram (TTS/STT) ──
DEEPGRAM_API_KEY=
