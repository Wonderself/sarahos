# ── Freenzy.io Dashboard — Environment Variables ──
# Copy this file to .env.local and fill in the values

# Backend API URL (default: http://localhost:3010)
NEXT_PUBLIC_API_URL=http://localhost:3010

# Dashboard admin API key (must match API_KEYS_ADMIN in backend .env)
DASHBOARD_API_KEY=

# ── Voice & Video APIs (optional) ──
DEEPGRAM_API_KEY=
DID_API_KEY=
ELEVENLABS_API_KEY=

# ── WhatsApp (optional) ──
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# ── Twilio (optional) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=

# ── AI Image & Video Generation (fal.ai) ──
FAL_KEY=

# ── Google Calendar (optional) ──
GOOGLE_CALENDAR_API_KEY=
