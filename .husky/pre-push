#!/bin/sh
# Quick sanity check before push — full test suite runs in CI (GitHub Actions)
echo "🧪 Quick pre-push check..."

# Lint must pass (no errors)
LINT_OUTPUT=$(npm run lint 2>&1 || true)
if echo "$LINT_OUTPUT" | grep -q "  error  "; then
  echo "❌ Lint errors — fix before pushing!"
  exit 1
fi

echo "✅ Pre-push OK — full tests run in CI"
