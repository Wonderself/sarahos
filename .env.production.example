# ═══════════════════════════════════════════════════════
# Freenzy.io — Production Environment Variables
# ═══════════════════════════════════════════════════════
# Copy to Coolify's environment variables panel
# ═══════════════════════════════════════════════════════

# ── REQUIRED (app will crash without these) ──────────
DB_PASSWORD=your-strong-db-password-32chars
DB_NAME=freenzy
DB_USER=freenzy
REDIS_PASSWORD=your-strong-redis-password
JWT_SECRET=your-jwt-secret-minimum-32-characters-long
ENCRYPTION_KEY=your-encryption-key-minimum-32-chars
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
API_KEYS_ADMIN=your-admin-api-key-min-16-chars

# ── DOMAINS (adapt to your setup) ───────────────────
DASHBOARD_ORIGIN=https://app.freenzy.io
NEXT_PUBLIC_API_URL=https://api.freenzy.io
WEBHOOK_BASE_URL=https://api.freenzy.io
APP_URL=https://app.freenzy.io

# ── OPTIONAL API KEYS ───────────────────────────────
API_KEYS_OPERATOR=operator-key-change-me
API_KEYS_VIEWER=viewer-key-change-this
API_KEYS_SYSTEM=system-key-change-this

# ── EMAIL (Resend) ──────────────────────────────────
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=Freenzy.io <noreply@freenzy.io>

# ── TWILIO (SMS + Voice + WhatsApp) ─────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM=

# ── WHATSAPP CLOUD API (Meta) ───────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=change-this-to-random-token

# ── ELEVENLABS (TTS) ────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ── AI MODELS (defaults are fine) ───────────────────
CLAUDE_MODEL_FAST=claude-sonnet-4-20250514
CLAUDE_MODEL_STANDARD=claude-sonnet-4-20250514
CLAUDE_MODEL_ADVANCED=claude-opus-4-6
CLAUDE_MODEL_ULTRAFAST=claude-haiku-4-5-20251001

# ── RATE LIMITING ───────────────────────────────────
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# ── GUARDRAILS ──────────────────────────────────────
GLOBAL_HOURLY_BUDGET=5000000
ADMIN_EMAIL=smadja99@gmail.com

# ── AUTOPILOT ───────────────────────────────────────
AUTOPILOT_ENABLED=false

# ── OPTIONAL (Studio, Calendar, etc.) ───────────────
FAL_KEY=
GOOGLE_CALENDAR_API_KEY=
DEEPGRAM_API_KEY=
DID_API_KEY=
